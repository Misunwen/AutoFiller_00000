{
  "manifest_version": 3,
  "name": "一定是(ゝ∀･)b",
  "version": "7.4.0",
  "description": "(ゝ∀･)b",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.tixcraft.com/*",
    "*://*.kktix.cc/*",
    "*://*.kktix.com/*",
    "*://*.ibon.com.tw/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tixcraft.com/*",
        "*://*.kktix.cc/*",
        "*://*.kktix.com/*",
        "*://*.ibon.com.tw/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://*.ibon.com.tw/*"]
    }
  ]
}
